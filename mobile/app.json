{
  "expo": {
    "name": "LayManagement",
    "slug": "shivapp",
    "version": "1.0.1",
    "scheme": "shivapp",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./logo-and-background/icon.png",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.shivapp.agency",
      "versionCode": 2,
      "allowBackup": false,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./logo-and-background/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos to upload employee photos, documents and payment proofs.",
          "microphonePermission": false
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./logo-and-background/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "335ae15b-687c-4376-b817-05eced37416d"
      }
    },
    "owner": "yashkarya"
  }
}
