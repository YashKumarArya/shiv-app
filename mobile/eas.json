{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "node": "20.19.4",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://shiv-app-production.up.railway.app/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.19.4",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://shiv-app-production.up.railway.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
