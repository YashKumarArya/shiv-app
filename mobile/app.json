{
  "expo": {
    "name": "Agency Manager",
    "slug": "shivapp",
    "version": "1.0.0",
    "scheme": "shivapp",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.shivapp.agency",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos to upload employee photos, documents and payment proofs."
        }
      ]
    ]
  }
}
